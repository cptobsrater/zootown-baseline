{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/og-image", "destination": "/api/og-image" },
    { "source": "/api/story-preview", "destination": "/api/story-preview" },
    { "source": "/:city/story/:storyId", "destination": "/api/story-preview" },
    {
      "source": "/:city",
      "has": [{ "type": "query", "key": "from_story" }],
      "destination": "/api/story-preview"
    },
    { "source": "/api/(.*)", "destination": "/api/[...path]" },
    { "source": "/((?!api/|assets/|.*\\..*).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/ingest", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/enrich", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/venue-ingest", "schedule": "0 * * * *" },
    { "path": "/api/cron/daily-writer", "schedule": "0 8 * * *" },
    { "path": "/api/cron/rotate-history", "schedule": "0 9 * * 1" },
    { "path": "/api/cron/anniversary-surfacer", "schedule": "0 12 * * *" },
    { "path": "/api/cron/editorial-audit", "schedule": "30 12 * * *" },
    { "path": "/api/cron/hs-sports", "schedule": "30 10,14,19,23 * * *" },
    { "path": "/api/cron/desk-sanity", "schedule": "0 13 * * *" },
    { "path": "/api/cron/athlete-enrichment", "schedule": "0 11 * * *" }
  ],
  "functions": {
    "api/[...path].ts": { "maxDuration": 30 },
    "api/story-preview.ts": { "maxDuration": 10 },
    "api/og-image.ts": { "maxDuration": 15 },
    "api/cron/ingest.ts": { "maxDuration": 60 },
    "api/cron/enrich.ts": { "maxDuration": 60 },
    "api/cron/venue-ingest.ts": { "maxDuration": 120 },
    "api/cron/daily-writer.ts": { "maxDuration": 30 },
    "api/cron/rotate-history.ts": { "maxDuration": 30 },
    "api/cron/anniversary-surfacer.ts": { "maxDuration": 30 },
    "api/cron/seed-historical-profiles.ts": { "maxDuration": 60 },
    "api/cron/editorial-audit.ts": { "maxDuration": 120 },
    "api/cron/hs-sports.ts": { "maxDuration": 120 },
    "api/cron/desk-sanity.ts": { "maxDuration": 120 },
    "api/cron/athlete-enrichment.ts": { "maxDuration": 120 },
    "api/cron/autofix-dupes.ts": { "maxDuration": 120 },
    "api/cron/retire-health.ts": { "maxDuration": 300 },
    "api/admin/preview-minute-script.ts": { "maxDuration": 60 }
  }
}
