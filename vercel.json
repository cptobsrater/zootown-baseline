{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...path]" },
    { "source": "/((?!api/|assets/|.*\\..*).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/ingest", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/daily-writer", "schedule": "0 8 * * *" },
    { "path": "/api/cron/rotate-history", "schedule": "0 9 * * 1" }
  ],
  "functions": {
    "api/[...path].ts": { "maxDuration": 30 },
    "api/cron/ingest.ts": { "maxDuration": 60 },
    "api/cron/daily-writer.ts": { "maxDuration": 30 },
    "api/cron/rotate-history.ts": { "maxDuration": 30 }
  }
}
